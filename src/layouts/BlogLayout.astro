---
import BaseLayout from './BaseLayout.astro';
import BridgeCTA from '../components/BridgeCTA.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  readingTime: number;
}

const { title, description, date, tags = [], readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-SG', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Claude Cowork`} description={description}>
  <article class="max-w-2xl mx-auto px-5 py-16">
    <header class="mb-10">
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-5">
        {tags.map((tag) => (
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-sky/20 dark:bg-sky/15 font-mono text-[9px] tracking-[1.5px] uppercase text-navy/70 dark:text-sky">
            #{tag}
          </span>
        ))}
      </div>

      <!-- Headline in Clash Display -->
      <h1 class="font-display font-semibold text-3xl md:text-4xl leading-tight text-navy dark:text-salt mb-4">
        {title}
      </h1>

      {description && (
        <p class="font-sans font-extrabold text-navy/50 dark:text-salt/50 text-lg mb-5 leading-relaxed">
          {description}
        </p>
      )}

      <!-- Metadata in DM Mono -->
      <div class="flex items-center gap-3 font-mono text-[10px] tracking-[1.5px] uppercase text-navy/40 dark:text-salt/40">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span>·</span>
        <span>{readingTime} min read</span>
      </div>

      <!-- Divider -->
      <div class="mt-8 h-px bg-sand dark:bg-white/10"></div>
    </header>

    <!-- Prose body -->
    <div class="prose prose-gray dark:prose-invert max-w-none
      prose-headings:font-display prose-headings:font-semibold prose-headings:tracking-tight
      prose-p:font-sans prose-p:font-extrabold prose-p:text-navy/70 dark:prose-p:text-salt/70
      prose-li:font-ui prose-li:text-navy/70 dark:prose-li:text-salt/70
      prose-strong:text-navy dark:prose-strong:text-salt
      prose-a:text-sea dark:prose-a:text-sky prose-a:no-underline hover:prose-a:underline
    ">
      <slot />
    </div>

    <div class="mt-14">
      <BridgeCTA />
    </div>
  </article>
</BaseLayout>
