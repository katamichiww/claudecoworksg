---
import BaseLayout from '../layouts/BaseLayout.astro';

const offerings = [
  {
    icon: '🎓',
    title: 'AI Workflow Bootcamps',
    desc: 'Intensive sessions where professionals build their first complete AI workflow from scratch — no coding, just real results.',
  },
  {
    icon: '🏢',
    title: 'Corporate Team Training',
    desc: 'Custom programs for teams making the shift from AI experimentation to AI-powered operations. Includes workflow audit.',
  },
  {
    icon: '🔧',
    title: 'AI Systems Consulting',
    desc: 'We design, document, and implement AI workflows for businesses ready to scale beyond one-off prompts.',
  },
];
---

<BaseLayout
  title="About Cowork SG — Independent AI Education Resource | claudecowork.sg"
  description="Cowork SG is an independent educational resource for non-technical professionals who want to build practical AI workflows. Built and curated by ANCHR AI Labs."
>
  <!-- Header -->
  <div class="relative overflow-hidden bg-navy px-5 py-14">
    <div class="grid-bg absolute inset-0 pointer-events-none"></div>
    <!-- Orbital watermark -->
    <div class="absolute right-[-2rem] top-1/2 -translate-y-1/2 pointer-events-none select-none opacity-[0.04]" aria-hidden="true">
      <svg width="320" height="320" viewBox="0 0 100 100" fill="none">
        <g stroke="#FAFAFA" stroke-width="1.2" fill="none">
          <ellipse cx="50" cy="50" rx="45" ry="18"/>
          <ellipse cx="50" cy="50" rx="45" ry="18" transform="rotate(45 50 50)"/>
          <ellipse cx="50" cy="50" rx="45" ry="18" transform="rotate(90 50 50)"/>
          <ellipse cx="50" cy="50" rx="45" ry="18" transform="rotate(135 50 50)"/>
        </g>
      </svg>
    </div>
    <div class="relative max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 mb-4">
        <span class="w-2 h-2 rounded-full bg-sea"></span>
        <span class="font-mono text-[10px] tracking-[2.5px] uppercase text-sky/70">About Cowork SG</span>
      </div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-salt tracking-tight mb-3">About</h1>
      <p class="font-sans font-extrabold text-salt/50 text-lg max-w-md leading-relaxed">
        An independent educational platform helping non-technical professionals build practical AI workflows — without coding, without confusion.
      </p>
    </div>
  </div>

  <section class="max-w-3xl mx-auto px-5 py-14 space-y-14">

    <!-- What is Cowork SG -->
    <div>
      <h2 class="font-display font-bold text-2xl text-navy dark:text-salt tracking-tight mb-5">What is Cowork SG?</h2>
      <div class="prose dark:prose-invert max-w-none
        prose-headings:font-display prose-p:font-sans prose-p:font-extrabold
        prose-p:text-navy/70 dark:prose-p:text-salt/70
        prose-strong:text-navy dark:prose-strong:text-salt
      ">
        <p>
          Cowork SG is an independent educational resource that teaches non-technical professionals how to use AI tools — like Claude, ChatGPT, and Gemini — to build real workflows, systems, and business outcomes.
        </p>
        <p>
          No coding. No technical background required. Just practical, step-by-step guidance for professionals who want to work smarter using AI.
        </p>
        <p>
          The platform is built and curated by <strong><a href="https://anchrlabs.com" target="_blank" rel="noopener noreferrer">ANCHR AI Labs</a></strong>, a Singapore-based company specialising in AI systems and training for non-technical professionals and corporate teams.
        </p>
      </div>
    </div>

    <!-- What ANCHR Offers -->
    <div>
      <h2 class="font-display font-bold text-2xl text-navy dark:text-salt tracking-tight mb-5">Training &amp; Services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {offerings.map(({ icon, title, desc }) => (
          <div class="p-5 rounded-2xl border border-sand dark:border-white/10 bg-salt dark:bg-white/5">
            <div class="text-2xl mb-3">{icon}</div>
            <h3 class="font-display font-bold text-[15px] text-navy dark:text-salt mb-2">{title}</h3>
            <p class="font-ui text-[13px] text-navy/60 dark:text-salt/50 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Perspective -->
    <div>
      <h2 class="font-display font-bold text-2xl text-navy dark:text-salt tracking-tight mb-5">Our perspective</h2>
      <div class="prose dark:prose-invert max-w-none
        prose-headings:font-display prose-p:font-sans prose-p:font-extrabold
        prose-p:text-navy/70 dark:prose-p:text-salt/70
        prose-blockquote:font-display prose-blockquote:italic
        prose-strong:text-navy dark:prose-strong:text-salt
      ">
        <p>
          AI tools are improving every month. But a better model doesn't automatically mean better outcomes for your business. What creates leverage is <strong>process</strong>.
        </p>
        <p>
          A team with documented, tested, repeatable AI workflows will always outperform a team that relies on individual prompting skill. We're tool-agnostic because the tools will keep changing. Systems scale.
        </p>
        <blockquote>"The goal isn't to use AI more. It's to build workflows that make AI work for you — automatically, consistently, and reliably."</blockquote>
        <p>
          Cowork SG is where we share what we know. ANCHR AI Labs is where we do the work with clients.
        </p>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="https://anchrlabs.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-full bg-navy dark:bg-salt text-salt dark:text-navy font-sans font-extrabold text-[16px] transition-transform hover:scale-[0.97] mr-4"
      >
        <span class="w-2.5 h-2.5 rounded-full bg-sea"></span>
        Visit ANCHR AI Labs →
      </a>
      <a
        href="/workshops"
        class="inline-flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-full border border-navy/20 dark:border-white/20 text-navy dark:text-salt font-sans font-bold text-[16px] transition-colors hover:border-sea/60 hover:text-sea mt-4 sm:mt-0"
      >
        View Workshops
      </a>
    </div>

    <!-- Legal Disclaimer -->
    <div class="rounded-xl border border-sand dark:border-white/10 bg-sand dark:bg-white/5 p-6">
      <h2 class="font-mono text-[10px] tracking-[2px] uppercase text-sea dark:text-sky mb-4">Independent Resource Notice</h2>
      <p class="font-ui text-[13px] text-navy/60 dark:text-salt/50 leading-relaxed mb-3">
        Cowork SG is an independent educational resource and is <strong class="text-navy dark:text-salt">not affiliated with, endorsed by, or associated with Anthropic or its products</strong>. The domain name "claudecowork.sg" is used for descriptive and informational purposes only. "Claude" is a trademark of its respective owner.
      </p>
      <p class="font-ui text-[13px] text-navy/60 dark:text-salt/50 leading-relaxed mb-3">
        All content on this website is provided for informational and educational purposes only. References to specific tools, platforms, or technologies (including Claude, ChatGPT, Gemini, and others) are made in a descriptive manner to illustrate general use cases and workflows.
      </p>
      <p class="font-ui text-[13px] text-navy/60 dark:text-salt/50 leading-relaxed">
        Cowork SG does not claim ownership of any third-party technologies and does not represent any official partnership, certification, or authorization from any AI tool provider. Users are advised to verify information independently and use AI tools in accordance with the respective providers' terms of service.
      </p>
    </div>

  </section>
</BaseLayout>
