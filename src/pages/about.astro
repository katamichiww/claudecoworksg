---
import BaseLayout from '../layouts/BaseLayout.astro';

const offerings = [
  {
    icon: '🎓',
    title: 'Bootcamps',
    desc: 'Intensive workshops where professionals build their first AI system from scratch in a single session.',
  },
  {
    icon: '🏢',
    title: 'Corporate Training',
    desc: 'Custom programs for teams making the shift from AI experimentation to AI-powered operations.',
  },
  {
    icon: '🔧',
    title: 'AI Systems Consulting',
    desc: 'We design, document, and implement AI workflows for businesses ready to scale beyond one-off prompts.',
  },
];
---

<BaseLayout
  title="About — ANCHR AI Labs"
  description="ANCHR AI Labs is the company behind Claude Cowork, building AI systems for professionals and businesses in Singapore and globally."
>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-4">About ANCHR AI Labs</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-14">
      The authority behind Claude Cowork — building AI systems, training operators, and helping businesses move from prompt users to system builders.
    </p>

    <div class="space-y-14">
      <div>
        <h2 class="text-2xl font-bold mb-5">What we do</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {offerings.map(({ icon, title, desc }) => (
            <div class="p-5 rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
              <div class="text-2xl mb-3">{icon}</div>
              <h3 class="font-semibold mb-2">{title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold mb-5">Our perspective</h2>
        <div class="prose dark:prose-invert max-w-none prose-a:text-brand-600 dark:prose-a:text-brand-400">
          <p>
            AI tools are getting better every month. Claude, ChatGPT, Gemini — the models will keep improving. But a better model doesn't automatically mean better outcomes for your business.
          </p>
          <p>
            What actually creates leverage is <strong>process</strong>. A team with documented, tested, repeatable AI workflows will always outperform a team that relies on individual prompting skill — no matter how good the underlying model gets.
          </p>
          <p>
            We're tool-agnostic because we believe the tools will change. Systems scale.
          </p>
          <blockquote>
            "Most people use AI tools. Operators build systems."
          </blockquote>
          <p>
            Claude Cowork is the content and learning hub where we share what we know. ANCHR AI Labs is where we do the work with clients.
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold mb-5">Founder</h2>
        <div class="flex gap-6 items-start p-6 rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
          <div class="w-16 h-16 rounded-full bg-gradient-to-br from-brand-400 to-accent-500 flex items-center justify-center text-white text-2xl font-bold flex-shrink-0">
            A
          </div>
          <div>
            <h3 class="font-bold text-lg mb-1">Founder, ANCHR AI Labs</h3>
            <p class="text-sm text-gray-500 dark:text-gray-500 mb-3">Singapore · AI Systems · PR Strategy</p>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              100+ global speaking engagements on AI, communications, and business systems. PR and AI positioning expert helping founders and corporate teams build authority in an AI-first world.
            </p>
          </div>
        </div>
      </div>

      <div class="text-center pt-2">
        <a
          href="/workshops"
          class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold transition-colors"
        >
          Work with us →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
