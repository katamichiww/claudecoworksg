---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function readingTime(body: string): number {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}
---

<BaseLayout
  title="Blog — Claude Cowork"
  description="Daily breakdowns on AI workflows, prompt engineering, and systems thinking for non-technical professionals."
>
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-3">Blog</h1>
      <p class="text-gray-600 dark:text-gray-400 text-lg max-w-xl">
        Daily breakdowns on AI workflows, prompt design, and systems thinking. Updated every weekday.
      </p>
    </div>

    {sorted.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-500">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sorted.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
