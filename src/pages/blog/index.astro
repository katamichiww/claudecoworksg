---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function readingTime(body: string): number {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}
---

<BaseLayout
  title="Blog — Claude Cowork"
  description="Daily breakdowns on AI workflows, prompt engineering, and systems thinking for non-technical professionals."
>
  <!-- Page header — Navy + grid -->
  <div class="relative overflow-hidden bg-navy px-5 py-14">
    <div class="grid-bg absolute inset-0 pointer-events-none"></div>
    <div class="relative max-w-6xl mx-auto">
      <div class="inline-flex items-center gap-2 mb-4">
        <span class="w-2 h-2 rounded-full bg-terra"></span>
        <span class="font-mono text-[10px] tracking-[2.5px] uppercase text-sky">Daily Updates</span>
      </div>
      <h1 class="font-display font-semibold text-4xl md:text-5xl text-salt tracking-tight mb-3">Blog</h1>
      <p class="font-sans font-extrabold text-salt/50 text-lg max-w-md">
        Daily breakdowns on AI workflows, prompt design, and systems thinking.
      </p>
    </div>
  </div>

  <section class="max-w-6xl mx-auto px-5 py-14">
    {sorted.length === 0 ? (
      <p class="font-ui text-navy/50 dark:text-salt/50">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {sorted.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
