---
const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-sand dark:border-white/10 bg-salt/95 dark:bg-navy/95 backdrop-blur-sm">
  <div class="max-w-3xl mx-auto px-5 h-14 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <svg width="26" height="26" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <g stroke="currentColor" stroke-width="4" stroke-linecap="round" fill="none" class="text-navy dark:text-salt group-hover:text-sea transition-colors">
          <ellipse cx="50" cy="50" rx="38" ry="15"/>
          <ellipse cx="50" cy="50" rx="38" ry="15" transform="rotate(45 50 50)"/>
          <ellipse cx="50" cy="50" rx="38" ry="15" transform="rotate(90 50 50)"/>
          <ellipse cx="50" cy="50" rx="38" ry="15" transform="rotate(135 50 50)"/>
        </g>
        <circle cx="12" cy="50" r="5" fill="#1B3464" class="dark:fill-salt"/>
        <circle cx="88" cy="50" r="5" fill="#1B3464" class="dark:fill-salt"/>
        <circle cx="61" cy="14" r="4" fill="#C84330"/>
        <circle cx="39" cy="86" r="4" fill="#D98B10"/>
        <circle cx="78" cy="72" r="3.5" fill="#C84330"/>
        <circle cx="22" cy="28" r="3.5" fill="#D98B10"/>
      </svg>
      <span class="font-display font-bold text-[17px] tracking-tight text-navy dark:text-salt group-hover:text-sea transition-colors">
        Cowork SG
      </span>
    </a>

    <!-- Nav -->
    <div class="flex items-center gap-6">
      <nav class="hidden sm:flex items-center gap-6">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'font-mono text-[11px] tracking-[2px] uppercase transition-colors',
              currentPath.startsWith(href)
                ? 'text-sea'
                : 'text-navy/45 dark:text-salt/45 hover:text-sea',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="p-1.5 rounded-full hover:bg-sand dark:hover:bg-white/10 transition-colors text-navy/40 dark:text-salt/40"
      >
        <svg class="hidden dark:block w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg class="block dark:hidden w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
