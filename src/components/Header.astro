---
const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/templates', label: 'Templates' },
  { href: '/workshops', label: 'Workshops' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-sand dark:border-white/10 bg-salt/95 dark:bg-navy/95 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-baseline gap-0.5 group">
      <span class="font-display font-semibold text-[22px] tracking-tight text-navy dark:text-salt leading-none group-hover:text-sea dark:group-hover:text-sky transition-colors">
        Claude Cowork
      </span>
      <span class="text-terra text-lg leading-none ml-1">⚓</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'font-mono text-[11px] tracking-[2px] uppercase transition-colors',
            currentPath.startsWith(href)
              ? 'text-sea dark:text-sky'
              : 'text-navy/50 dark:text-salt/50 hover:text-sea dark:hover:text-sky',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <!-- Desktop CTA -->
      <a
        href="/workshops"
        class="hidden md:inline-flex items-center gap-2 px-5 py-2 rounded-full bg-navy dark:bg-salt text-salt dark:text-navy font-sans font-extrabold text-[14px] transition-transform hover:scale-[0.97] whitespace-nowrap"
      >
        <span class="w-2 h-2 rounded-full bg-sky flex-shrink-0"></span>
        Book Training
      </a>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="p-2 rounded-full hover:bg-sand dark:hover:bg-white/10 transition-colors text-navy/50 dark:text-salt/50"
      >
        <svg class="hidden dark:block w-4.5 h-4.5 w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg class="block dark:hidden w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        aria-label="Toggle navigation"
        class="md:hidden p-2 rounded-full hover:bg-sand dark:hover:bg-white/10 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-sand dark:border-white/10 bg-salt dark:bg-navy">
    <div class="px-5 py-4 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'font-mono text-[11px] tracking-[2px] uppercase py-2.5 px-2 rounded-lg transition-colors',
            currentPath.startsWith(href)
              ? 'text-sea dark:text-sky bg-sky/10'
              : 'text-navy/50 dark:text-salt/50 hover:text-sea dark:hover:text-sky',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="/workshops"
        class="mt-2 inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-navy dark:bg-salt text-salt dark:text-navy font-sans font-extrabold text-sm w-fit"
      >
        <span class="w-2 h-2 rounded-full bg-sky"></span>
        Book Training
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
