---
const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/templates', label: 'Templates' },
  { href: '/workshops', label: 'Workshops' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-950/90 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-lg tracking-tight hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
      Claude Cowork
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors hover:text-brand-600 dark:hover:text-brand-400',
            currentPath.startsWith(href)
              ? 'text-brand-600 dark:text-brand-400'
              : 'text-gray-600 dark:text-gray-400',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-600 dark:text-gray-400"
      >
        <!-- Sun icon: visible in dark mode -->
        <svg class="hidden dark:block w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <!-- Moon icon: visible in light mode -->
        <svg class="block dark:hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <button
        id="mobile-menu-btn"
        aria-label="Toggle navigation menu"
        class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
    <div class="px-4 py-3 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium py-2 px-2 rounded-lg transition-colors hover:text-brand-600 dark:hover:text-brand-400',
            currentPath.startsWith(href)
              ? 'text-brand-600 dark:text-brand-400 bg-brand-50 dark:bg-brand-900/20'
              : 'text-gray-600 dark:text-gray-400',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
