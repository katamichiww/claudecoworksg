---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
  readingTime: number;
}

const { title, description, date, slug, tags = [], readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-SG', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group p-6 rounded-2xl border border-sand dark:border-white/10 bg-salt dark:bg-white/5 hover:border-sky/50 dark:hover:border-sky/40 hover:shadow-md transition-all duration-200 flex flex-col">
  <!-- Tags — Sky Blue pill tags (brand motif) -->
  <div class="flex flex-wrap gap-1.5 mb-3">
    {tags.slice(0, 3).map((tag) => (
      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-sky/20 dark:bg-sky/15 font-mono text-[9px] tracking-[1px] uppercase text-navy/70 dark:text-sky">
        #{tag}
      </span>
    ))}
  </div>

  <a href={`/blog/${slug}`} class="flex-1">
    <h3 class="font-display font-semibold text-[17px] mb-2 text-navy dark:text-salt group-hover:text-sea dark:group-hover:text-sky transition-colors leading-snug">
      {title}
    </h3>
  </a>
  <p class="font-ui text-[13px] text-navy/60 dark:text-salt/50 leading-relaxed mb-5 line-clamp-2">{description}</p>

  <div class="flex items-center justify-between mt-auto">
    <time datetime={date.toISOString()} class="font-mono text-[9px] tracking-[1px] uppercase text-navy/40 dark:text-salt/40">
      {formattedDate}
    </time>
    <span class="font-mono text-[9px] tracking-[1px] uppercase text-navy/40 dark:text-salt/40">
      {readingTime} min read
    </span>
  </div>
</article>
