<section class="relative overflow-hidden py-20 md:py-28 lg:py-36 px-4">
  <!-- Background gradient blobs -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-accent-50/40 dark:from-gray-950 dark:via-gray-950 dark:to-accent-900/10"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-100/60 dark:bg-brand-900/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-accent-100/50 dark:bg-accent-900/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-100 dark:bg-brand-900/30 text-brand-700 dark:text-brand-300 text-sm font-medium mb-6">
      <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
      Powered by ANCHR AI Labs
    </div>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6">
      Learn how professionals use<br class="hidden md:block" />
      <span class="text-brand-600 dark:text-brand-400">AI tools like Claude</span><br class="hidden md:block" />
      to build real systems
    </h1>

    <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Most people use AI tools. Operators build systems. Claude Cowork teaches non-technical professionals how to turn one-off prompts into repeatable workflows — using any AI tool in their stack.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/workshops"
        class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold transition-colors shadow-sm"
      >
        Build your first AI system in 60 minutes
      </a>
      <a
        href="/blog"
        class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-900 font-semibold transition-colors"
      >
        Read the blog →
      </a>
    </div>

    <p class="mt-6 text-sm text-gray-500 dark:text-gray-500">
      Tool-agnostic — works with Claude, ChatGPT, Gemini, and any AI in your stack.
    </p>
  </div>
</section>
