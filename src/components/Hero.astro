---
---

<section class="relative overflow-hidden bg-navy py-20 md:py-28 lg:py-36 px-5">
  <!-- Graph-paper grid texture -->
  <div class="grid-bg absolute inset-0 pointer-events-none"></div>

  <!-- Giant anchor watermark -->
  <div
    class="absolute right-[-2rem] top-1/2 -translate-y-1/2 font-playfair italic text-[22rem] leading-none pointer-events-none select-none"
    style="color: rgba(189,213,234,0.04);"
    aria-hidden="true"
  >
    ⚓
  </div>

  <div class="relative max-w-4xl mx-auto">
    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-2.5 mb-7">
      <span class="w-2 h-2 rounded-full bg-terra animate-pulse"></span>
      <span class="font-mono text-[10px] tracking-[2.5px] uppercase text-sky">
        Powered by ANCHR AI Labs
      </span>
    </div>

    <!-- Headline — Clash Display with Playfair italic accent -->
    <h1 class="font-display font-semibold text-5xl md:text-6xl lg:text-[4.5rem] leading-[1.05] tracking-tight text-salt mb-6">
      Learn how professionals use<br class="hidden md:block" />
      <span class="font-playfair italic text-sky">AI tools like Claude</span><br class="hidden md:block" />
      to build real systems
    </h1>

    <!-- Body — DM Sans 800 at 50% opacity (brand spec) -->
    <p class="font-sans font-extrabold text-salt/50 text-lg md:text-xl max-w-2xl leading-relaxed mb-10">
      Most people use AI tools. Operators build systems. Claude Cowork teaches non-technical professionals how to turn one-off prompts into repeatable workflows — using any AI tool in their stack.
    </p>

    <!-- CTAs — pill buttons with decorative dot -->
    <div class="flex flex-col sm:flex-row gap-4 mb-12">
      <a
        href="/workshops"
        class="inline-flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-full bg-salt text-navy font-sans font-extrabold text-[17px] transition-transform hover:scale-[0.97]"
      >
        <span class="w-2.5 h-2.5 rounded-full bg-sea flex-shrink-0"></span>
        Build your first AI system in 60 minutes
      </a>
      <a
        href="/blog"
        class="inline-flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-full border border-salt/20 text-salt font-sans font-bold text-[17px] transition-colors hover:border-sky/60 hover:text-sky"
      >
        Read the blog →
      </a>
    </div>

    <!-- Stats cards — from brand kit layout sample -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { label: 'AI Tools Covered', value: '5+' },
        { label: 'Workflow Templates', value: '20+' },
        { label: 'Daily Blog Updates', value: '✓' },
        { label: 'No Coding Required', value: '✓' },
      ].map(({ label, value }) => (
        <div
          class="rounded-xl p-4 border"
          style="background: rgba(189,213,234,0.07); border-color: rgba(189,213,234,0.2);"
        >
          <p class="font-mono text-[9px] tracking-[1px] uppercase text-sky/70 mb-1.5">{label}</p>
          <p class="font-display font-semibold text-2xl text-sky leading-none">{value}</p>
        </div>
      ))}
    </div>

    <!-- Fine print -->
    <p class="mt-6 font-ui text-sm text-salt/30">
      Tool-agnostic — Claude, ChatGPT, Gemini, and any AI in your stack.
    </p>
  </div>
</section>
