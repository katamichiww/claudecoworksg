---
interface Props {
  icon: string;
  title: string;
  description: string;
  time?: string;
}

const { icon, title, description, time } = Astro.props;
---

<div class="group p-6 rounded-2xl border border-sand dark:border-white/10 bg-salt dark:bg-white/5 hover:border-sky/50 dark:hover:border-sky/40 hover:shadow-md transition-all duration-200">
  <div class="text-3xl mb-4">{icon}</div>
  <h3 class="font-display font-semibold text-[17px] mb-2 text-navy dark:text-salt group-hover:text-sea dark:group-hover:text-sky transition-colors leading-snug">
    {title}
  </h3>
  <p class="font-ui text-[13px] text-navy/60 dark:text-salt/50 leading-relaxed mb-4">{description}</p>
  {time && (
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-sky/10 dark:bg-sky/20">
      <svg class="w-3 h-3 text-sea dark:text-sky flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      <span class="font-mono text-[9px] tracking-[1px] uppercase text-sea dark:text-sky">
        Fast win: {time}
      </span>
    </div>
  )}
</div>
