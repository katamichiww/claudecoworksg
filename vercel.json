{
  "buildCommand": "sh build.sh",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    { "source": "/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/blog-ai-services-new-software", "destination": "/blog/ai-services-new-software", "permanent": true },
    { "source": "/blog-claude-architect-exam", "destination": "/blog/claude-architect-exam", "permanent": true },
    { "source": "/blog-claude-cowork-beginners", "destination": "/blog/claude-cowork-beginners", "permanent": true },
    { "source": "/blog-claude-cowork-capabilities", "destination": "/blog/claude-cowork-capabilities", "permanent": true },
    { "source": "/blog-claude-prompting-outcome-first", "destination": "/blog/claude-prompting-outcome-first", "permanent": true },
    { "source": "/blog-claude-whatsapp", "destination": "/blog/claude-whatsapp", "permanent": true },
    { "source": "/blog-shipped-to-prod-5-hours", "destination": "/blog/shipped-to-prod-5-hours", "permanent": true },
    { "source": "/blog-claude-cowork-what-it-is", "destination": "/blog/claude-cowork-what-it-is", "permanent": true }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "<https://claudecowork.sg/llms.txt>; rel=\"describedby\", <https://claudecowork.sg/sitemap.xml>; rel=\"sitemap\", <https://claudecowork.sg/.well-known/api-catalog>; rel=\"api-catalog\""
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    },
    {
      "source": "/.well-known/api-catalog",
      "headers": [{ "key": "Content-Type", "value": "application/linkset+json" }]
    },
    {
      "source": "/.well-known/mcp/server-card.json",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    },
    {
      "source": "/.well-known/agent-skills/index.json",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ]
}
